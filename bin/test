#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TEST_ROOT="${OPSFORGE_TEST_OUTPUT:-$ROOT/.ci-artifacts}"

usage() {
  cat <<'USAGE'
Usage:
  bin/test syntax
  bin/test help
  bin/test shellcheck
  bin/test forbidden-files
  bin/test wrapper-targets
  bin/test script-catalog
  bin/test output-contract
  bin/test linux-fixtures
  bin/test linux-feasibility
  bin/test runtime-linux
  bin/test readability
  bin/test all

Runs local validation for opsforge. The tests are read-only against the host and
write their own evidence under .ci-artifacts/ unless OPSFORGE_TEST_OUTPUT is set.
USAGE
}

say() {
  printf '[test] %s\n' "$*"
}

fail() {
  printf '[test] ERROR: %s\n' "$*" >&2
  exit 1
}

make_run_dir() {
  local name="$1"
  local stamp dir
  stamp="$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$TEST_ROOT"
  dir="$(mktemp -d "$TEST_ROOT/$name-$stamp.XXXXXX")"
  chmod 755 "$dir"
  printf '%s\n' "$dir"
}

assert_file() {
  local file="$1"
  [ -f "$file" ] || fail "expected file was not created: $file"
}

assert_dir() {
  local dir="$1"
  [ -d "$dir" ] || fail "expected directory was not created: $dir"
}

assert_nonempty_file() {
  local file="$1"
  assert_file "$file"
  [ -s "$file" ] || fail "expected file to be non-empty: $file"
}

assert_text() {
  local file="$1"
  local pattern="$2"
  grep -F "$pattern" "$file" >/dev/null 2>&1 || fail "expected '$pattern' in $file"
}

latest_output_dir() {
  local base="$1"
  local match="$2"
  find "$base" -mindepth 1 -maxdepth 1 -type d -name "*-$match-*" -printf '%T@ %p\n' |
    sort -n |
    awk 'END {print $2}'
}

assert_output_contract() {
  local out_dir="$1"
  "$ROOT/bin/validate-output-contract" "$out_dir" >/dev/null
}

assert_contracts_under() {
  local base="$1"
  local count=0
  while IFS= read -r findings; do
    assert_output_contract "$(dirname "$findings")"
    count=$((count + 1))
  done < <(find "$base" -mindepth 2 -maxdepth 2 -name findings.json | sort)
  [ "$count" -gt 0 ] || fail "no script output directories found under $base"
  say "validated output contracts=$count"
}

run_runtime_linux_one() {
  local name="$1"
  local script_name="$2"
  shift 2
  say "runtime-linux: $name"
  "$@"
  local out_dir
  out_dir="$(latest_output_dir "$OPSFORGE_RUNTIME_OUTPUT_DIR" "$script_name")"
  [ -n "$out_dir" ] || fail "$name did not create an output directory"
  printf '[test] runtime-linux output: %s\n' "$out_dir"
  "$ROOT/bin/validate-output-contract" "$out_dir"
}

test_syntax() {
  say "checking bash syntax"
  while IFS= read -r file; do
    bash -n "$file"
  done < <(find "$ROOT/bin" "$ROOT/lib" "$ROOT/scripts" -type f \( -name '*.sh' -o -name opsforge -o -name test \) | sort)
}

test_help() {
  say "checking linux script help output"
  while IFS= read -r file; do
    "$file" --help >/dev/null
  done < <(find "$ROOT/scripts/linux" -type f -name '*.sh' | sort)
  "$ROOT/bin/opsforge" >/dev/null 2>&1 && fail "opsforge without arguments should exit non-zero"
  [ "$?" -eq 2 ] || fail "opsforge without arguments should exit 2"
}

test_shellcheck() {
  if ! command -v shellcheck >/dev/null 2>&1; then
    say "shellcheck not installed; skipping"
    return 0
  fi
  say "running shellcheck"
  mapfile -t files < <(find "$ROOT/bin" "$ROOT/lib" "$ROOT/scripts/linux" -type f \( -name '*.sh' -o -name opsforge -o -name test \) | sort)
  shellcheck -S error "${files[@]}"
}

test_forbidden_files() {
  say "checking forbidden core language files"
  local files
  files="$(find "$ROOT" \
    -path "$ROOT/.git" -prune -o \
    -path "$ROOT/.ci-artifacts" -prune -o \
    -path "$ROOT/output" -prune -o \
    -type f \( \
      -name '*.py' -o -name '*.go' -o -name '*.rs' -o -name '*.js' -o \
      -name '*.ts' -o -name '*.rb' -o -name '*.pl' -o -name '*.exe' -o \
      -name '*.dll' -o -name '*.so' -o -name '*.dylib' \
    \) -print)"
  [ -z "$files" ] || fail "forbidden core language or binary files found: $files"
}

test_readability() {
  say "checking source readability"
  local failed=0
  while IFS= read -r file; do
    if [ -f "$file" ] && grep -Iq . "$file"; then
      awk 'length($0) > 500 {printf "%s:%d: line length %d\n", FILENAME, NR, length($0); bad=1} END {exit bad ? 1 : 0}' "$file" ||
        failed=1
    fi
  done < <(
    find "$ROOT" \
      -path "$ROOT/.git" -prune -o \
      -path "$ROOT/.ci-artifacts" -prune -o \
      -path "$ROOT/output" -prune -o \
      -path "$ROOT/examples" -prune -o \
      -type f \( \
        -name '*.md' -o -name '*.sh' -o -name '*.ps1' -o -name '*.yml' -o \
        -name '*.yaml' -o -name '*.conf' -o -name '.gitignore' -o \
        -path "$ROOT/bin/opsforge" -o -path "$ROOT/bin/test" -o \
        -path "$ROOT/bin/validate-output-contract" \
      \) -print | sort
  )
  [ "$failed" -eq 0 ] || fail "readability check failed"
}

test_wrapper_targets() {
  say "checking wrapper target paths"
  local target
  while IFS= read -r target; do
    [ -f "$ROOT/$target" ] || fail "Bash wrapper references missing script: $target"
  done < <(sed -n 's/.*exec "$ROOT\/\([^"]*\)".*/\1/p' "$ROOT/bin/opsforge" | sort)

  while IFS= read -r target; do
    target="${target//\\//}"
    [ -f "$ROOT/$target" ] || fail "PowerShell wrapper references missing script: $target"
  done < <(sed -n 's/.*Join-Path \$Root '"'"'\([^'"'"']*\)'"'"'.*/\1/p' "$ROOT/bin/opsforge.ps1" | sort)
}

test_script_catalog() {
  say "checking script catalog consistency"
  local script documented
  while IFS= read -r script; do
    documented="$(grep -F "\`$script\`" "$ROOT/docs/script-catalog.md" || true)"
    [ -n "$documented" ] || fail "script is missing from docs/script-catalog.md: $script"
  done < <(cd "$ROOT" && find scripts -type f \( -name '*.sh' -o -name '*.ps1' \) | sort)

  while IFS= read -r script; do
    [ -f "$ROOT/$script" ] || fail "docs/script-catalog.md references missing script: $script"
  done < <(grep -o '`scripts/[^`]*`' "$ROOT/docs/script-catalog.md" | tr -d '`' | sort -u)
}

test_output_contract() {
  say "checking output contract fixture"
  "$ROOT/bin/validate-output-contract" "$ROOT/tests/fixtures/output-contract-valid" >/dev/null
}

test_linux_fixtures() {
  say "running linux fixture tests"
  local run_dir fixture_dir home_dir log_file persistence_dir net_cfg tls_cfg silence_cfg
  run_dir="$(make_run_dir linux-fixtures)"
  fixture_dir="$ROOT/tests/fixtures/linux"
  home_dir="$run_dir/home"
  cp -R "$fixture_dir/home" "$home_dir"
  mkdir -p "$home_dir/.ssh" "$run_dir/logs"
  cp "$fixture_dir/logs/app.fixture" "$run_dir/logs/app.log"

  HOME="$home_dir" "$ROOT/bin/opsforge" linux persistence --output "$run_dir" --quiet
  persistence_dir="$(latest_output_dir "$run_dir" linux-persistence-hunter)"
  [ -n "$persistence_dir" ] || fail "persistence hunter did not create an output directory"
  assert_file "$persistence_dir/findings.json"
  assert_text "$persistence_dir/findings.json" "LINUX-PERSISTENCE"
  assert_text "$persistence_dir/report.md" "Suspicious Matches"
  assert_output_contract "$persistence_dir"

  log_file="$run_dir/logs/app.log"
  silence_cfg="$run_dir/log-sources.conf"
  printf 'fixture-app|%s|critical|1440\n' "$log_file" > "$silence_cfg"
  "$ROOT/bin/opsforge" linux log-silence --config "$silence_cfg" --output "$run_dir" --quiet
  assert_output_contract "$(latest_output_dir "$run_dir" log-source-silence-detector)"

  net_cfg="$run_dir/network-targets.conf"
  cp "$fixture_dir/network-targets.conf" "$net_cfg"
  "$ROOT/bin/opsforge" linux net-drift --targets "$net_cfg" --output "$run_dir" --quiet
  assert_text "$(latest_output_dir "$run_dir" network-path-drift)/findings.json" "LINUX-NETPATH-TCP"
  assert_output_contract "$(latest_output_dir "$run_dir" network-path-drift)"

  tls_cfg="$run_dir/tls-targets.conf"
  cp "$fixture_dir/tls-targets.conf" "$tls_cfg"
  "$ROOT/bin/opsforge" linux tls --targets "$tls_cfg" --output "$run_dir" --quiet
  assert_text "$(latest_output_dir "$run_dir" tls-inventory-scanner)/findings.json" "TLS-"
  assert_output_contract "$(latest_output_dir "$run_dir" tls-inventory-scanner)"

  say "fixture evidence: $run_dir"
}

run_one() {
  local name="$1"
  shift
  echo "::group::$name"
  local log="$LINUX_FEASIBILITY_ROOT/$name.log"
  if ! timeout 180 "$@" >"$log" 2>&1; then
    echo "::endgroup::"
    printf '::error::%s failed\n' "$name"
    cat "$log"
    return 1
  fi
  cat "$log"
  echo "::endgroup::"
}

test_linux_feasibility() {
  say "running linux feasibility suite"
  local cfg summaries
  LINUX_FEASIBILITY_ROOT="$(make_run_dir linux-feasibility)"
  export LINUX_FEASIBILITY_ROOT
  cfg="$LINUX_FEASIBILITY_ROOT/config"
  mkdir -p "$cfg"
  printf 'localhost|127.0.0.1|1\n' > "$cfg/network-targets.conf"
  printf 'localhost|127.0.0.1|1\n' > "$cfg/tls-targets.conf"
  printf 'tmp-log|%s/test.log|critical|1440\n' "$cfg" > "$cfg/log-sources.conf"
  printf 'test\n' > "$cfg/test.log"

  run_one triage "$ROOT/bin/opsforge" linux triage --output "$LINUX_FEASIBILITY_ROOT"
  run_one persistence "$ROOT/bin/opsforge" linux persistence --output "$LINUX_FEASIBILITY_ROOT"
  run_one deleted "$ROOT/bin/opsforge" linux deleted-binaries --output "$LINUX_FEASIBILITY_ROOT"
  run_one proc-tree "$ROOT/bin/opsforge" linux proc-tree --output "$LINUX_FEASIBILITY_ROOT"
  run_one suid-baseline "$ROOT/bin/opsforge" linux suid --baseline --baseline-file "$cfg/suid-baseline.txt" --output "$LINUX_FEASIBILITY_ROOT"
  run_one suid-check "$ROOT/bin/opsforge" linux suid --check --baseline-file "$cfg/suid-baseline.txt" --output "$LINUX_FEASIBILITY_ROOT"
  run_one priv-surface "$ROOT/bin/opsforge" linux priv-surface --output "$LINUX_FEASIBILITY_ROOT"
  run_one ssh-audit "$ROOT/bin/opsforge" linux ssh-audit --output "$LINUX_FEASIBILITY_ROOT"
  run_one config-baseline "$ROOT/bin/opsforge" linux config-drift --baseline --baseline-dir "$cfg/config-baseline" --output "$LINUX_FEASIBILITY_ROOT"
  run_one config-check "$ROOT/bin/opsforge" linux config-drift --check --baseline-dir "$cfg/config-baseline" --output "$LINUX_FEASIBILITY_ROOT"
  run_one net-drift "$ROOT/bin/opsforge" linux net-drift --targets "$cfg/network-targets.conf" --output "$LINUX_FEASIBILITY_ROOT"
  run_one tls "$ROOT/bin/opsforge" linux tls --targets "$cfg/tls-targets.conf" --output "$LINUX_FEASIBILITY_ROOT"
  run_one firewall "$ROOT/bin/opsforge" linux firewall --output "$LINUX_FEASIBILITY_ROOT"
  run_one disk-rca "$ROOT/bin/opsforge" linux disk-rca --output "$LINUX_FEASIBILITY_ROOT"
  run_one log-silence "$ROOT/bin/opsforge" linux log-silence --config "$cfg/log-sources.conf" --output "$LINUX_FEASIBILITY_ROOT"
  run_one timeline "$ROOT/bin/opsforge" linux timeline --since-hours 1 --output "$LINUX_FEASIBILITY_ROOT"
  run_one web-triage "$ROOT/bin/opsforge" linux web-triage --output "$LINUX_FEASIBILITY_ROOT"

  summaries="$(find "$LINUX_FEASIBILITY_ROOT" -maxdepth 2 -name summary.txt | wc -l)"
  [ "$summaries" -ge 16 ] || fail "expected at least 16 summary files, got $summaries"
  assert_contracts_under "$LINUX_FEASIBILITY_ROOT"
  say "linux feasibility summaries=$summaries"
  say "linux feasibility evidence: $LINUX_FEASIBILITY_ROOT"
}

test_runtime_linux() {
  say "running Linux runtime validation"
  OPSFORGE_RUNTIME_OUTPUT_DIR="${OPSFORGE_RUNTIME_OUTPUT:-$ROOT/output}"
  if ! mkdir -p "$OPSFORGE_RUNTIME_OUTPUT_DIR" 2>/dev/null ||
    [ ! -w "$OPSFORGE_RUNTIME_OUTPUT_DIR" ]; then
    if [ -n "${OPSFORGE_RUNTIME_OUTPUT:-}" ]; then
      fail "runtime output directory is not writable: $OPSFORGE_RUNTIME_OUTPUT_DIR"
    fi
    OPSFORGE_RUNTIME_OUTPUT_DIR="$TEST_ROOT/runtime-output"
    say "output/ is not writable; using $OPSFORGE_RUNTIME_OUTPUT_DIR"
  fi
  export OPSFORGE_RUNTIME_OUTPUT_DIR
  mkdir -p "$OPSFORGE_RUNTIME_OUTPUT_DIR"

  run_runtime_linux_one \
    triage \
    linux-triage-collector \
    "$ROOT/bin/opsforge" linux triage \
    --output "$OPSFORGE_RUNTIME_OUTPUT_DIR" --markdown --json

  run_runtime_linux_one \
    persistence \
    linux-persistence-hunter \
    "$ROOT/bin/opsforge" linux persistence \
    --output "$OPSFORGE_RUNTIME_OUTPUT_DIR" --markdown --json

  run_runtime_linux_one \
    deleted-binaries \
    deleted-binary-detector \
    "$ROOT/bin/opsforge" linux deleted-binaries \
    --output "$OPSFORGE_RUNTIME_OUTPUT_DIR" --markdown --json

  run_runtime_linux_one \
    disk-rca \
    disk-pressure-rca \
    "$ROOT/bin/opsforge" linux disk-rca \
    --output "$OPSFORGE_RUNTIME_OUTPUT_DIR" --markdown --json

  if [ -f "$ROOT/configs/linux/tls-targets.conf" ]; then
    run_runtime_linux_one \
      tls \
      tls-inventory-scanner \
      "$ROOT/bin/opsforge" linux tls \
      --targets "$ROOT/configs/linux/tls-targets.conf" \
      --output "$OPSFORGE_RUNTIME_OUTPUT_DIR" --markdown --json
  fi
}

case "${1:-}" in
  syntax) test_syntax ;;
  help) test_help ;;
  shellcheck) test_shellcheck ;;
  forbidden-files) test_forbidden_files ;;
  readability) test_readability ;;
  wrapper-targets) test_wrapper_targets ;;
  script-catalog) test_script_catalog ;;
  output-contract) test_output_contract ;;
  linux-fixtures) test_linux_fixtures ;;
  linux-feasibility) test_linux_feasibility ;;
  runtime-linux) test_runtime_linux ;;
  all)
    test_syntax
    test_help
    test_shellcheck
    test_forbidden_files
    test_readability
    test_wrapper_targets
    test_script_catalog
    test_output_contract
    test_linux_fixtures
    test_linux_feasibility
    test_runtime_linux
    ;;
  -h|--help) usage ;;
  *) usage; exit 2 ;;
esac
